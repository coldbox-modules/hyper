{
    "name":"hyper-boxlang@be",
    "app":{
        "serverHomeDirectory":".engine/boxlangBE",
        "cfengine":"boxlang@be"
    },
    "web":{
        "http":{
            "port":"8500"
        },
        "rewrites": {
            "enable": true
        }
    },
    "JVM": {
        "heapSize": "1024",
        "javaVersion": "openjdk21_jre",
        "args":"-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=8888"
    },
    "openBrowser": false,
    "env": {},
    "scripts": {
        "onServerInitialInstall": "install bx-esapi"
    }
}